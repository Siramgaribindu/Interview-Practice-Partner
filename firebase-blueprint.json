{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role, email, and created details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "email", "role"]
    },
    "InterviewSession": {
      "title": "InterviewSession",
      "description": "An interview session with an AI Practice Partner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["ongoing", "completed"] },
        "createdAt": { "type": "string" },
        "completedAt": { "type": "string" },
        "chatHistory": {
          "type": "array",
          "items": { "type": "object" }
        },
        "feedback": { "type": "object" }
      },
      "required": ["id", "userId", "role", "status", "createdAt", "chatHistory"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Store user profiles, including custom settings like display names and roles"
    },
    "/interviews/{interviewId}": {
      "schema": "InterviewSession",
      "description": "Store all practice interview sessions and progress details"
    }
  }
}
